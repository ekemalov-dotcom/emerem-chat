# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# Comma-separated origins (або * для всіх)
# Приклад: ALLOWED_ORIGINS=https://emerem.ua,https://www.emerem.ua
ALLOWED_ORIGINS=*

# ── SMTP (відправка email менеджеру) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Від кого відображається лист
SMTP_FROM=your-email@gmail.com

# ── Email менеджера (куди слати гарячих лідів) ────────────────────────────────
MANAGER_EMAIL=manager@emerem.ua
